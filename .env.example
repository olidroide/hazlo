DATABASE_URL=postgresql+asyncpg://hazlo:hazlo@localhost:5433/hazlo
HAZLO_ENV=dev
HAZLO_SECRET_KEY=<generate-with-python-secrets>
# CA_BUNDLE=/path/to/certifi+corporate-ca-bundle.pem  # required behind corporate proxy
VERIFY_SSL=true
ADMIN_USER=admin
ADMIN_PASSWORD=<strong-password>
HAZLO_AUTO_MIGRATE=1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash
LLM_TIMEOUT=30
LLM_MAX_RETRIES=2
AUTO_APPROVE_THRESHOLD=0.95
